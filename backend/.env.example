# ------------------------------------------------------------------
# Django Core
# ------------------------------------------------------------------
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------
# Database (PostgreSQL / 배포 시 AWS RDS)
# ------------------------------------------------------------------
DB_NAME=ezen_anshim
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ------------------------------------------------------------------
# CORS (React 프론트엔드)
# ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------
# AWS S3 (프로필 이미지 업로드)
# ------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-northeast-2

# ------------------------------------------------------------------
# AI / RAG (윤승혁 담당 영역, chat_rag에서 사용)
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./data/vector_db
CHROMA_COLLECTION_NAME=youth_opportunity_chunks
TAVILY_API_KEY=

# Neo4j AuraDB (Hybrid RAG, graph_service.py)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ------------------------------------------------------------------
# 외부 검색 (Tavily Fallback, rag_engine/services/external_search_service.py)
# ------------------------------------------------------------------
TAVILY_API_KEY=
EXTERNAL_WEB_SEARCH_ENABLED=true
ENABLE_DDG_HTML_SEARCH=false
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_RAW_CONTENT=false
CURRENT_POLICY_YEAR=2026